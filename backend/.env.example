# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=minimum-32-char-random-string-change-this

# ── Database ─────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/voicepost?retryWrites=true&w=majority

# ── Cache (Upstash — use REST, not ioredis) ───────
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── LinkedIn OAuth ────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback

# ── AI ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Payments ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_STARTER=plan_starter_id
RAZORPAY_PLAN_PRO=plan_pro_id
RAZORPAY_PLAN_SCALE=plan_scale_id
RAZORPAY_PLAN_GLOBAL=plan_global_id

# ── Email ─────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=noreply@voicepost.in
